APP_NAME="Notification Service"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=notification_service
DB_USERNAME=app
DB_PASSWORD=secret

CACHE_STORE=redis

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

QUEUE_CONNECTION=rabbitmq

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_VHOST=notifications
RABBITMQ_USER=app
RABBITMQ_PASSWORD=secret
RABBITMQ_QUEUE=notifications.transactional

# Gateway drivers: 'mock' | 'real'
NOTIFICATION_SMS_GATEWAY=mock
NOTIFICATION_EMAIL_GATEWAY=mock

# Swagger
L5_SWAGGER_GENERATE_ALWAYS=true
